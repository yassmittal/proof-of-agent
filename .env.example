# Sui testnet keypair (bech32 "suiprivkey1...") used by all scripts.
# Generate one with:  npm run keygen   (then paste the printed secret here)
SUI_PRIVATE_KEY=

# Sui fullnode (gRPC). Testnet default below.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Published audit_anchor Move package ID (from `sui client publish`).
AUDIT_ANCHOR_PACKAGE_ID=

# Model credentials for the live agent. Set EITHER of the following; without either,
# `bun run record-run` falls back to a deterministic simulated agent.
#
# First-party Anthropic API:
ANTHROPIC_API_KEY=
#
# ...or Amazon Bedrock (takes precedence when set). AWS_REGION defaults to us-east-1.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Persistent agent + issuer identity (hex private keys). Generate with `bun run agent-keys`
# and paste the two printed lines here, so the agent keeps a stable DID across runs.
# If unset, a fresh identity is minted each run (fine for a one-off, but no run history).
AGENT_PRIVATE_KEY=
ISSUER_PRIVATE_KEY=

# Sui testnet keypair (bech32 "suiprivkey1...") used by all scripts.
# Generate one with:  npm run keygen   (then paste the printed secret here)
SUI_PRIVATE_KEY=

# Sui fullnode (gRPC). Testnet default below.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Published audit_anchor Move package ID (from `sui client publish`).
AUDIT_ANCHOR_PACKAGE_ID=

# Anthropic API key. When set, `bun run record-run` uses a live Claude agent;
# without it the pipeline falls back to a deterministic simulated agent.
ANTHROPIC_API_KEY=
